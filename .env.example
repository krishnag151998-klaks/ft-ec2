# =============================================================================
# Family Tree Application — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# PostgreSQL / RDS Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=familytree
DB_PASSWORD=familytree_secret
DB_NAME=familytree

# Next.js
NODE_ENV=production

# Amazon Cognito Configuration
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=
