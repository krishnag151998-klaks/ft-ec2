# =============================================================================
# Family Tree Application — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# PostgreSQL Configuration
POSTGRES_USER=familytree
POSTGRES_PASSWORD=familytree_secret
POSTGRES_DB=familytree

# Database URL (used by Prisma)
# When running via Docker Compose, the host is the service name "db".
# When running locally, change "db" to "localhost".
DATABASE_URL=postgresql://familytree:familytree_secret@db:5432/familytree?schema=public

# Next.js
NODE_ENV=production
